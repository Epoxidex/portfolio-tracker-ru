# Copy this file to .env. Never commit the resulting .env file.

# Use a read-only T-Invest API token. Leave empty to run without T-Invest.
TINVEST_TOKEN=

# Optional. If empty, the first account available to the token is used.
TINVEST_ACCOUNT_ID=

# The official SDK can report SDK failures to T-Bank's diagnostic service.
# This local app disables that channel by default; set 1 only if you opt in.
TINVEST_SDK_ERROR_REPORTING=0

# Use the MinTsifry root certificate bundled with the official Python SDK.
SSL_TBANK_VERIFY=true

# Dashboard progress target in RUB.
PORTFOLIO_GOAL=1000000

# Earliest broker-operation and snapshot date, YYYY-MM-DD.
# Choose this before the first T-Invest import; leave empty only for full history.
PORTFOLIO_TRACKING_START_DATE=

# cbr (official CBR rate), bank_buy, or bank_sell.
# The two bank_* modes scrape one bank page configured below and can break
# when the third-party page changes. cbr is the safest default for a fresh clone.
FX_RATE_SOURCE=cbr
BANKIROS_URL=https://bankiros.ru/bank/kamkombank/currency

# Background jobs run only while the application is open. 0 disables a job.
SNAPSHOT_EVERY_MIN=60
FETCH_EVERY_MIN=0
FX_EVERY_MIN=0

# Optional private Git repository for unencrypted SQLite backups from the UI.
# Keep the URL free of credentials; Git uses the system credential manager.
# The repository must remain private. Authenticate Git once in a terminal first.
BACKUP_GIT_REPOSITORY=
BACKUP_GIT_BRANCH=main

# Optional database location. Relative paths are resolved from the project root.
# DB_PATH=portfolio.db
